{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@tmo/shared": ["../../packages/shared/src/index.ts"],
      "@tmo/shared/*": ["../../packages/shared/src/*"]
    },
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": false,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*", "legacy/**/*"]
}
