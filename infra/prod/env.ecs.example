# Copy to infra/prod/env.ecs.local before first deployment.

COMPOSE_PROJECT_NAME=tmo
IMAGE_REPO=tmo
IMAGE_TAG=ecs
DOCKERHUB_MIRROR_PREFIX=
GCR_MIRROR_PREFIX=

# Build network settings.
BUILD_GOPROXY=https://proxy.golang.org,direct
BUILD_GOSUMDB=sum.golang.org
BUILD_GONOSUMDB=

# Host bind paths on ECS.
POSTGRES_DATA_DIR=../../data/postgres
MEDIA_HOST_DIR=../../data/media

# Shared database.
POSTGRES_DB=commerce
POSTGRES_USER=commerce
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

IDENTITY_DB_DSN=postgres://commerce:change-me@postgres:5432/identity?sslmode=disable
COMMERCE_DB_DSN=postgres://commerce:change-me@postgres:5432/commerce?sslmode=disable
PAYMENT_DB_DSN=postgres://commerce:change-me@postgres:5432/payment?sslmode=disable

# Public API entrypoint.
GATEWAY_PUBLIC_BASE_URL=https://api.example.com
MEDIA_PUBLIC_BASE_URL=https://api.example.com/assets/media

# Public admin-web entrypoint and build output.
ADMIN_WEB_PUBLIC_BASE_URL=https://admin.example.com
ADMIN_WEB_API_BASE_URL=https://api.example.com
ADMIN_WEB_BASE_PATH=/
ADMIN_WEB_DIST_DIR=/var/www/tmo-admin

# JWT and internal service secrets.
IDENTITY_JWT_SECRET=change-me-long-random-string
IDENTITY_JWT_ISSUER=tmo-identity
COMMERCE_JWT_SECRET=change-me-long-random-string
COMMERCE_JWT_ISSUER=tmo-identity
COMMERCE_INTERNAL_SYNC_TOKEN=change-me-sync-token
PAYMENT_COMMERCE_SYNC_TOKEN=change-me-sync-token

# App behavior.
IDENTITY_LOGIN_MODE=real
IDENTITY_ENABLE_PHONE_PROOF_SIMULATION=false
IDENTITY_PHONE_PROOF_SIMULATION_PHONE=+15550009999
IDENTITY_ENABLE_DEBUG_ROLE_SWITCH=false

COMMERCE_AUTH_ENABLED=true
PAYMENT_AUTH_ENABLED=false
PAYMENT_PROVIDER_MODE=mock
PAYMENT_ENABLED=false
PAYMENT_WECHAT_PAY_ENABLED=false
PAYMENT_ALIPAY_PAY_ENABLED=false

GATEWAY_UPSTREAM_TIMEOUT=10s
GATEWAY_MAX_BODY_BYTES=33554432
GATEWAY_IMAGE_PROXY_ALLOWLIST=images.unsplash.com
GATEWAY_IMAGE_PROXY_TIMEOUT=30s
GATEWAY_IMAGE_PROXY_MAX_BYTES=8388608
GATEWAY_IMAGE_PROXY_CACHE_MAX_AGE_SECONDS=3600

# Optional production credentials.
IDENTITY_WEAPP_APPID=
IDENTITY_WEAPP_APPSECRET=
IDENTITY_ALIPAY_APP_ID=
IDENTITY_ALIPAY_PRIVATE_KEY=
IDENTITY_ALIPAY_PUBLIC_KEY=
IDENTITY_ALIPAY_AES_KEY=
